rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: userId (auth.uid)
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string
    //   - photoURL: string
    //   - dailyUsageCount: int
    //   - lastUsageDate: string (YYYY-MM-DD)
    //   - role: string (user/admin)
    //
    // Collection: plans
    // Document ID: planId (hash of prompt)
    // Fields:
    //   - promptHash: string (required)
    //   - plan: map (required)
    //   - createdAt: timestamp (required)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          ((request.auth.token.email == "lovejapan12345@gmail.com" || request.auth.token.email == "saigonpension2025@gmail.com") && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string &&
             (!('dailyUsageCount' in data) || data.dailyUsageCount is int) &&
             (!('role' in data) || data.role in ['user', 'admin']);
    }

    function isValidPlan(data) {
      return data.keys().hasAll(['promptHash', 'plan', 'createdAt']) &&
             data.promptHash is string &&
             data.plan is map &&
             data.createdAt is timestamp;
    }

    function isValidPreferences(data) {
      return data.keys().hasAll(['uid', 'updatedAt']) &&
             data.uid is string &&
             data.updatedAt is timestamp &&
             (!('budget' in data) || data.budget in ['low', 'medium', 'high']) &&
             (!('travelStyle' in data) || data.travelStyle in ['relaxed', 'balanced', 'active']) &&
             (!('interests' in data) || data.interests is list) &&
             (!('dietary' in data) || data.dietary in ['none', 'vegetarian', 'halal', 'gluten-free']);
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && 
                    (!('role' in request.resource.data) || request.resource.data.role == 'user' || isAdmin());
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                    (request.resource.data.role == resource.data.role || isAdmin());

      match /preferences/main {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId) && isValidPreferences(request.resource.data);
      }
    }

    match /plans/{planId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidPlan(request.resource.data);
      allow update: if false;
    }
  }
}
