# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# =========================
# Checkout (Upgrade Plans)
# =========================
# Example: Stripe/LemonSqueezy checkout URLs
# Build-time fallback (Vite):
VITE_CHECKOUT_BASIC_URL="https://checkout.example.com/basic"
VITE_CHECKOUT_PRO_URL="https://checkout.example.com/pro"
# Runtime (recommended for Cloud Run):
CHECKOUT_BASIC_URL="https://checkout.example.com/basic"
CHECKOUT_PRO_URL="https://checkout.example.com/pro"

# =========================
# Branded Affiliate Redirect
# =========================
# Keep affiliate URLs server-side only.
# JSON map: slug -> full affiliate URL
# Example:
# AFFILIATE_LINKS_JSON='{"tokyo-disneyland":"https://affiliate.example.com/abc"}'
AFFILIATE_LINKS_JSON='{}'

# =========================
# eSIM Provider API (Server-side)
# =========================
# Backend will call:
#   GET {ESIM_PROVIDER_BASE_URL}/plans?country=JP
#   POST {ESIM_PROVIDER_BASE_URL}/orders
ESIM_PROVIDER_BASE_URL="https://api.esim-provider.com"
ESIM_PROVIDER_API_KEY="YOUR_PROVIDER_API_KEY"

# =========================
# PayPay Gateway (Server-side)
# =========================
# Required for PayPay QR checkout in eSIM payment sheet.
# PAYPAY_MODE: staging | live (or prod)
PAYPAY_MODE="staging"
PAYPAY_API_KEY="YOUR_PAYPAY_API_KEY"
PAYPAY_API_SECRET="YOUR_PAYPAY_API_SECRET"
# Optional (some merchant setups require this)
PAYPAY_MERCHANT_ID=""
# Optional override return URL after scan/pay
# PAYPAY_REDIRECT_URL="https://olachill.com/?payment=paypay&status=return"
